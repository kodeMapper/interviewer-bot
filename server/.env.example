# Express Server Environment Variables
# Copy to .env and fill in your values

PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
CLIENT_URL=http://localhost:3000
ML_SERVICE_URL=http://127.0.0.1:8000
PROCTOR_URL=http://127.0.0.1:5000
SESSION_SECRET=change-this-in-production

# Google Gemini API (used for resume-based question generation)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: comma-separated pool for key rotation
GEMINI_API_KEYS=key1,key2,key3

# Optional alternatives (if platform rejects commas in one value):
# GEMINI_API_KEY_1=key1
# GEMINI_API_KEY_2=key2
# GEMINI_API_KEY_3=key3

# Optional alphanumeric-only names (for strict env-key UIs):
# GEMINIAPIKEY1=key1
# GEMINIAPIKEY2=key2
# GEMINIAPIKEY3=key3
